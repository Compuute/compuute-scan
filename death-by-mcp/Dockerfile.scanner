# Minimal scanner image for Death by MCP
# Non-root, minimal surface area
FROM node:22-alpine

RUN addgroup -S scanner && adduser -S scanner -G scanner
RUN apk add --no-cache git

WORKDIR /home/scanner
COPY lib/compuute-scan.js /home/scanner/compuute-scan.js
RUN chmod +x /home/scanner/compuute-scan.js

RUN mkdir -p /work && chown scanner:scanner /work

USER scanner
WORKDIR /work
